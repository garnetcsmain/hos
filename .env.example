# HOS environment configuration. Copy to apps/web/.env.local and fill in.
# .env files are gitignored. Never commit real secrets (AGENTS.md §3).
#
# The MVP runs fully WITHOUT any of these set: persistence is local SQLite
# (node:sqlite, no setup) and matching falls back to the deterministic
# rule engine. Add keys below to layer cloud AI and lock down coordinator access.

# --- Cloud AI providers (optional, pluggable, multiple at once) -------------
# Matching uses the local rule engine as a baseline and blends in any provider
# configured here. Providers auto-enable when their key is present; or pin the
# set/order explicitly with HOS_AI_PROVIDERS.
#
# HOS_AI_PROVIDERS=anthropic,openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Per-provider model / endpoint overrides (optional):
# HOS_ANTHROPIC_MODEL=claude-opus-4-8      # default; use claude-haiku-4-5 for cheap high-volume scoring
# HOS_OPENAI_MODEL=gpt-4o-mini
# HOS_ANTHROPIC_BASE_URL=https://api.anthropic.com
# HOS_OPENAI_BASE_URL=https://api.openai.com

# --- Coordinator access gate (optional) ------------------------------------
# When set, coordinator endpoints (full PII, matches, verify, notifications)
# require header  x-hos-coordinator-token: <value>. Unset = open in dev.
HOS_COORDINATOR_TOKEN=

# --- Storage (optional) ----------------------------------------------------
# Path to the SQLite file. Defaults to apps/web/.data/hos.db. Use :memory: for
# an ephemeral store.
# HOS_DB_PATH=

# --- Map embed (optional, public) ------------------------------------------
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps?ll=10.545,-66.990&z=10&t=m&output=embed
